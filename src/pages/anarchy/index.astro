---
import AnarchyLayout from "../../layouts/AnarchyLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getDevlogPosts } from "../../lib/blog";

const posts = await getDevlogPosts();
---

<AnarchyLayout
  title="Anarchy — Devlog"
  description="Dev blog for Anarchy, a game in progress by Bridge Apps."
  path="/anarchy"
  backHref="/"
  backLabel="Bridge Apps"
>
  <header class="zine__masthead">
    <h1 class="zine__title">Anarchy</h1>
    <span class="zine__tag">Devlog</span>
  </header>

  {
    posts.length === 0 ? (
      <p class="devlog__empty">No entries yet. Stay tuned.</p>
    ) : (
      <ul class="devlog">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </ul>
    )
  }
</AnarchyLayout>
